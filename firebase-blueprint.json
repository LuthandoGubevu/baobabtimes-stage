{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "fullName": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "phone": { "type": "string" },
        "jobTitle": { "type": "string" },
        "department": { "type": "string" },
        "bio": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "ceo", "user"] },
        "preferences": {
          "type": "object",
          "properties": {
            "theme": { "type": "string", "enum": ["light", "dark", "system"] },
            "language": { "type": "string" },
            "timezone": { "type": "string" },
            "landingPage": { "type": "string" }
          }
        },
        "notifications": {
          "type": "object",
          "properties": {
            "emailOnRecognition": { "type": "boolean" },
            "emailOnArticle": { "type": "boolean" },
            "ceoUpdates": { "type": "boolean" },
            "systemAlerts": { "type": "boolean" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["displayName", "email", "role"]
    },
    "Article": {
      "title": "Article",
      "description": "News articles and company updates",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "category": { "type": "string" },
        "status": { "type": "string", "enum": ["DRAFT", "PUBLISHED", "ARCHIVED"] },
        "featuredImage": { "type": "string" },
        "views": { "type": "integer" },
        "isPinned": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "authorId", "status"]
    },
    "Recognition": {
      "title": "Recognition",
      "description": "Peer-to-peer recognition messages",
      "type": "object",
      "properties": {
        "fromId": { "type": "string" },
        "fromName": { "type": "string" },
        "fromAvatar": { "type": "string" },
        "toId": { "type": "string" },
        "toName": { "type": "string" },
        "toAvatar": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string" },
        "categories": { "type": "array", "items": { "type": "string" } },
        "dateString": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "APPROVED", "REJECTED"] },
        "isAnonymous": { "type": "boolean" },
        "likes": { "type": "integer" },
        "likedBy": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fromId", "toId", "content", "status"]
    },
    "AmaQuestion": {
      "title": "AMA Question",
      "description": "Questions for the CEO",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "content": { "type": "string" },
        "upvotes": { "type": "integer" },
        "status": { "type": "string", "enum": ["PENDING", "APPROVED", "REJECTED", "ANSWERED"] },
        "answer": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["content", "status"]
    },
    "CeoMessage": {
      "title": "CEO Message",
      "description": "Direct messages from the CEO",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "status": { "type": "string", "enum": ["DRAFT", "PUBLISHED"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "authorId", "status"]
    },
    "Activity": {
      "title": "Activity",
      "description": "Platform-wide activity feed items",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["article_published", "recognition_posted", "ceo_message_published", "announcement_published", "spotlight_published"] },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "entityId": { "type": "string" },
        "entitySlug": { "type": "string" },
        "url": { "type": "string" },
        "metadata": {
          "type": "object",
          "properties": {
            "category": { "type": "string" },
            "authorName": { "type": "string" },
            "recognitionValue": { "type": "string" },
            "fromName": { "type": "string" },
            "toName": { "type": "string" }
          }
        },
        "isPublic": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "title", "isPublic", "createdAt"]
    },
    "ThisIsMeVideo": {
      "title": "This Is Me Video",
      "description": "Episodes of the 'This is me' video series",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "youtubeUrl": { "type": "string" },
        "thumbnail": { "type": "string" },
        "duration": { "type": "string" },
        "category": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "likes": { "type": "integer" },
        "commentsCount": { "type": "integer" },
        "status": { "type": "string", "enum": ["DRAFT", "PUBLISHED"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "youtubeUrl", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/articles/{articleId}": {
      "schema": "Article",
      "description": "Published and draft articles"
    },
    "/recognitions/{recognitionId}": {
      "schema": "Recognition",
      "description": "Employee recognitions"
    },
    "/ama_questions/{questionId}": {
      "schema": "AmaQuestion",
      "description": "CEO AMA questions"
    },
    "/ceo_messages/{messageId}": {
      "schema": "CeoMessage",
      "description": "CEO messages"
    },
    "/activity/{activityId}": {
      "schema": "Activity",
      "description": "Recent platform activity"
    },
    "/this_is_me/{videoId}": {
      "schema": "ThisIsMeVideo",
      "description": "Videos in the 'This is me' series"
    }
  }
}
